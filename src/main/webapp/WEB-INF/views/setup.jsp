<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!doctype html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Khởi tạo quản trị viên</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><style>body{min-height:100vh;display:grid;place-items:center;background:#f1f5f9}.box{width:min(460px,92vw);border:0;border-radius:18px;box-shadow:0 16px 45px rgba(15,23,42,.12)}</style></head><body><div class="card box"><div class="card-body p-4 p-md-5"><h1 class="h4 fw-bold">Khởi tạo quản trị viên</h1><p class="text-muted">Màn hình này tự khóa vĩnh viễn sau khi tài khoản đầu tiên được tạo.</p><c:if test="${not empty error}"><div class="alert alert-danger"><c:out value="${error}"/></div></c:if><form method="post"><div class="mb-3"><label class="form-label">Họ và tên</label><input class="form-control" name="fullName" required></div><div class="mb-3"><label class="form-label">Tên đăng nhập</label><input class="form-control" name="username" minlength="3" required autocomplete="username"></div><div class="mb-4"><label class="form-label">Mật khẩu</label><input type="password" class="form-control" name="password" minlength="8" required autocomplete="new-password"><div class="form-text">Tối thiểu 8 ký tự, được băm BCrypt trước khi lưu.</div></div><button class="btn btn-primary w-100">Tạo quản trị viên</button></form></div></div></body></html>
